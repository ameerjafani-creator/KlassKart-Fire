
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Store for Klass Kart user account details.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "user",
            "admin"
          ]
        }
      },
      "required": [
        "uid",
        "email"
      ]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order and its payment status.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "paymentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingAddress": { "type": "object" }
      },
      "required": ["orderId", "items", "totalAmount", "status"]
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profiles indexed by their unique Firebase UID."
    },
    "/orders/{orderId}": {
      "schema": "#/entities/Order",
      "description": "Customer orders and payment records."
    }
  }
}
